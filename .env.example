# Optional: https://dev.pokemontcg.io/ — raises rate limit to 20k/day
POKEMONTCG_API_KEY=

# Server
PORT=3001

# Authentication
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_REFRESH_SECRET=change-this-to-another-random-secret
DATABASE_PATH=./data/pokegrails.sqlite

# Google OAuth (optional; https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=

# eBay (optional; Browse API OAuth — free developer tier)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENVIRONMENT=production

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# PriceCharting (Legendary tier for CSV/API + chart scraping)
PRICECHARTING_API_KEY=

# Public URL for Card Show QR (e.g. http://localhost:5173)
PUBLIC_APP_URL=http://localhost:5173

# ── Local dev: pull sanitized prod snapshot ─────────────────────────
# Used by `npm run snapshot` and `npm run dev:prod-data`. The snapshot
# script SSHes to the production host, takes a WAL-consistent .backup,
# scrubs all users except POKEGRAILS_ADMIN_EMAIL, wipes tokens / stripe
# ids, and installs the result at ./data/pokegrails.sqlite.
POKEGRAILS_SSH_HOST=
POKEGRAILS_SSH_USER=deploy
POKEGRAILS_SSH_KEY=~/.ssh/id_ed25519
# Your real prod email. The snapshot script KEEPS this account and deletes
# every other user. If it matches zero users in prod, sanitize refuses to
# run (so a placeholder like you@example.com can't silently wipe the DB).
POKEGRAILS_ADMIN_EMAIL=
POKEGRAILS_LOCAL_PASSWORD=devdev123
# Snapshot older than this (hours) triggers a re-pull in `npm run dev:prod-data`.
# Default 24. Bump to e.g. 168 to reuse the same snapshot for a whole week.
# Override per-run with:  npm run dev:prod-data -- --fresh    (force pull)
#                         npm run dev:prod-data -- --no-pull  (skip pull, reuse)
POKEGRAILS_SNAPSHOT_MAX_AGE_HOURS=24

# ── Local dev: mint a throwaway admin (no prod match required) ───────
# `npm run local:admin` (or scripts/create-local-admin.sh) inserts-or-updates
# an admin account in the local dev DB. Independent of the snapshot flow —
# useful when POKEGRAILS_ADMIN_EMAIL doesn't match anyone in prod, or when
# you want a separate always-known test login.
POKEGRAILS_LOCAL_ADMIN_EMAIL=admin@local.dev
POKEGRAILS_LOCAL_ADMIN_USERNAME=localadmin
