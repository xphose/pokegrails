# PokeGrails Production Environment
NODE_ENV=production
PORT=3001

# Database
DATABASE_PATH=/app/data/pokegrails.sqlite

# Domain (used by Caddy for automatic HTTPS)
DOMAIN=pokegrails.com

# CORS (comma-separated origins)
CORS_ORIGINS=https://pokegrails.com,https://www.pokegrails.com

# Authentication (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=
JWT_REFRESH_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=

# Pokemon TCG API
POKEMONTCG_API_KEY=

# PriceCharting
PRICECHARTING_API_KEY=

# eBay (optional)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENVIRONMENT=production

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@pokegrails.com

# Public URL
PUBLIC_APP_URL=https://pokegrails.com

# Stripe (for premium subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=
