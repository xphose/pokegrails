# Sentinel configuration — copy to /etc/sentinel/config.env and fill in.
# Lines starting with # are comments. All values are optional except the
# alert channel(s) you actually want to use.

# ---------------- alert channels ----------------

# ntfy.sh — free, no signup. Install the ntfy app on your phone and subscribe
# to your secret topic. Pick something unguessable (anyone with the topic name
# can read your alerts).
# Generate: `openssl rand -hex 12` → e.g. pokegrails-sentinel-3f9a...
NTFY_TOPIC=

# Override if you self-host ntfy or want a different server
# NTFY_URL=https://ntfy.sh

# Discord webhook URL (optional; nice for a persistent alert history channel)
# Server Settings → Integrations → Webhooks → New Webhook → copy URL
DISCORD_WEBHOOK_URL=

# healthchecks.io dead-man's switch. Create a free account, add a check with
# a 10-min period + 5-min grace, and paste the ping URL here. If Sentinel
# stops pinging, HC will email/SMS you.
HEALTHCHECKS_PING_URL=

# ---------------- identity ----------------

# Shows up in every alert title. Defaults to `hostname -s`.
# SENTINEL_HOSTNAME=pokegrails-prod

# ---------------- what to monitor ----------------

# Space-separated Docker container names to check
SENTINEL_CONTAINERS="pokegrails pokegrails-dev pokegrails-caddy pokegrails-backup"

# Space-separated canary URLs
SENTINEL_CANARY_URLS="https://pokegrails.com/api/canary https://dev.pokegrails.com/api/canary"

# Hostnames whose TLS certs to monitor
SENTINEL_TLS_HOSTS="pokegrails.com dev.pokegrails.com"

# ---------------- thresholds ----------------

# Disk usage (%)
SENTINEL_DISK_WARN_PCT=85
SENTINEL_DISK_FAIL_PCT=95

# Host RAM — alert when AVAILABLE drops below these (MB)
SENTINEL_MEM_WARN_AVAIL_MB=500
SENTINEL_MEM_FAIL_AVAIL_MB=150

# Swap usage (%)
SENTINEL_SWAP_WARN_PCT=50

# Load average multipliers (vs nproc)
SENTINEL_LOAD_WARN_MULT=2
SENTINEL_LOAD_FAIL_MULT=4

# TLS cert expiry (days remaining)
SENTINEL_TLS_WARN_DAYS=14
SENTINEL_TLS_FAIL_DAYS=5

# Log lookback window (systemd / docker logs --since accepts "5m", "10m", "1h")
SENTINEL_LOG_LOOKBACK=5m

# ---------------- behavior ----------------

# Alert cooldown (seconds) — same key won't fire more often than this
SENTINEL_COOLDOWN_SEC=900

# Flap window & threshold — if an alert fires >N times in window, suppress
SENTINEL_FLAP_WINDOW_SEC=3600
SENTINEL_FLAP_THRESHOLD=3

# Attempt `docker restart` once before alerting on a stopped container (0|1)
SENTINEL_SELF_HEAL=1
