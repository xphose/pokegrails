{$DOMAIN:localhost} {
	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# NOTE: use the unambiguous container name `pokegrails`, not the service
	# alias `app`. The dev compose project (`pokegrails-dev/docker-compose.dev.yml`)
	# also registers `app` on the shared `pokegrails_web` network, so Docker's
	# embedded DNS returns BOTH container IPs for `app:3001`, and Caddy then
	# round-robins — silently sending ~50% of prod traffic to the dev container.
	# That was the root cause of the 2026-04-18 "prod is running pre-af5cc65 code"
	# ghost-deploy incident: the new image was live, but half the requests were
	# being served by the long-lived dev container.
	reverse_proxy pokegrails:3001

	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}

dev.pokegrails.com {
	@notapi not path /api/*
	basicauth @notapi {
		# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
		# dev YOUR_BCRYPT_HASH_HERE
	}

	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	reverse_proxy pokegrails-dev:3001

	log {
		output file /data/dev-access.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}
