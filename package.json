{
  "name": "pokegrails",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev -w web\" \"npm run dev -w server\"",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w server",
    "dev:prod-data": "bash scripts/dev-with-prod-data.sh",
    "snapshot": "bash scripts/pull-prod-snapshot.sh",
    "local:admin": "bash scripts/create-local-admin.sh",
    "build": "npm run build -w server && npm run build -w web",
    "start": "npm run start -w server",
    "test": "npm run test -w server && npm run test -w web",
    "test:server": "npm run test -w server",
    "test:web": "npm run test -w web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
